---
const roles = [
  {
    title: 'Slack Community Manager',
    hours: '5-8 hrs/week',
    skills: 'Community moderation, engagement strategy, bilingual preferred',
    icon: '💬',
  },
  {
    title: 'Customer Discovery Lead',
    hours: '5-8 hrs/week',
    skills: 'User research, interview skills, empathy mapping',
    icon: '🔍',
  },
  {
    title: 'Social Media Coordinator',
    hours: '4-6 hrs/week',
    skills: 'LinkedIn/Instagram, Canva, healthcare content creation',
    icon: '📱',
  },
  {
    title: 'Events Coordinator',
    hours: '4-6 hrs/week',
    skills: 'Event planning, logistics, Eventbrite/Luma, RSVP management',
    icon: '📅',
  },
  {
    title: 'Grant Writer',
    hours: '10-15 hrs total',
    skills: 'Foundation grant experience, LOI drafting, budget narrative',
    icon: '✍️',
  },
  {
    title: 'Web Developer',
    hours: '5-10 hrs total',
    skills: 'Astro/Next.js, responsive design, CMS setup',
    icon: '💻',
  },
  {
    title: 'Content Writer',
    hours: '3-5 hrs/week',
    skills: 'Healthcare writing, storytelling, newsletter production',
    icon: '📝',
  },
];
---

<section class="section-padding bg-dark">
  <div class="container-narrow">
    <div class="text-center mb-16">
      <h2 class="font-display text-3xl sm:text-4xl font-bold text-white mb-4 fade-in tracking-tight">
        Open Roles
      </h2>
      <p class="text-gray-400 text-lg max-w-2xl mx-auto fade-in">
        We're building the founding team. Every role is a 90-day sprint commitment.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 stagger-children">
      {roles.map((role) => (
        <div class="glass-card fade-in group hover:border-purple/30">
          <div class="text-3xl mb-4">{role.icon}</div>
          <h3 class="font-display font-bold text-white text-lg mb-2 group-hover:text-purple-300 transition-colors">
            {role.title}
          </h3>
          <div class="inline-flex items-center gap-1 px-2 py-1 bg-purple/10 border border-purple/20 rounded text-xs font-medium text-purple-300 mb-3">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            {role.hours}
          </div>
          <p class="text-gray-400 text-sm leading-relaxed">{role.skills}</p>
        </div>
      ))}
    </div>
  </div>
</section>
