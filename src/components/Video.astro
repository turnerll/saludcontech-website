<!-- Video section — LMSA Conference Highlights 2024 -->
<section class="section-padding bg-dark-100">
  <div class="container-narrow">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-10 fade-in">
        <h2 class="font-display text-3xl sm:text-4xl font-bold text-white mb-4 tracking-tight">See Our Story</h2>
        <p class="text-gray-400 text-lg">Hear directly from our founder about why SaludConTech exists.</p>
      </div>

      <div class="fade-in">
        <div
          id="video-placeholder"
          data-youtube-id="hKrr1jXQhs8"
          class="relative aspect-video bg-gradient-to-br from-dark-200 to-dark rounded-2xl overflow-hidden shadow-xl border border-white/10"
        >
          <!-- Animated placeholder -->
          <div id="video-placeholder-content" class="absolute inset-0 flex flex-col items-center justify-center text-white">
            <div class="w-20 h-20 rounded-full bg-purple/80 flex items-center justify-center mb-6 hover:bg-purple transition-colors cursor-pointer group">
              <svg class="w-8 h-8 ml-1 group-hover:scale-110 transition-transform" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z"/>
              </svg>
            </div>
            <p class="text-gray-500 text-sm font-medium">Watch our highlights</p>
          </div>

          <!-- Decorative grid overlay -->
          <div class="absolute inset-0 opacity-5">
            <div class="grid grid-cols-8 grid-rows-6 h-full">
              {Array.from({ length: 48 }).map(() => (
                <div class="border border-white/20" />
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    // Auto-embed YouTube when ID is provided (using safe DOM methods)
    (function() {
      var placeholder = document.getElementById('video-placeholder');
      var videoId = placeholder ? placeholder.getAttribute('data-youtube-id') : '';
      if (videoId && videoId.trim()) {
        // Validate video ID format (alphanumeric + hyphens/underscores only)
        if (/^[a-zA-Z0-9_-]+$/.test(videoId)) {
          var placeholderContent = document.getElementById('video-placeholder-content');
          if (placeholderContent) placeholderContent.remove();

          var iframe = document.createElement('iframe');
          iframe.className = 'absolute inset-0 w-full h-full';
          iframe.src = 'https://www.youtube.com/embed/' + encodeURIComponent(videoId);
          iframe.title = 'SaludConTech';
          iframe.setAttribute('frameborder', '0');
          iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';
          iframe.allowFullscreen = true;
          placeholder.appendChild(iframe);
        }
      }
    })();
  </script>
</section>
