<section class="section-padding bg-dark-100">
  <div class="container-narrow">
    <div class="max-w-xl mx-auto text-center">
      <h2 class="font-display text-2xl sm:text-3xl font-bold text-white mb-4 fade-in tracking-tight">
        Stay in the Loop
      </h2>
      <p class="text-gray-400 mb-8 fade-in">
        Get monthly updates on community events, founder stories, and opportunities in Latino health tech.
      </p>

      <form
        id="newsletter-form"
        class="flex flex-col sm:flex-row gap-3 fade-in"
        action="#"
        method="POST"
      >
        <input
          type="email"
          name="email"
          required
          placeholder="your@email.com"
          class="flex-1 px-5 py-3.5 rounded-lg border border-white/10 bg-white/5 text-white placeholder:text-gray-500
                 focus:outline-none focus:ring-2 focus:ring-purple/50 focus:border-purple transition-all"
        />
        <button type="submit" class="btn-primary whitespace-nowrap">
          Subscribe
        </button>
      </form>

      <p class="text-gray-600 text-xs mt-4 fade-in">
        No spam. Unsubscribe anytime.
      </p>

      <!-- Success message (hidden by default) -->
      <div id="newsletter-success" class="hidden mt-4 p-4 bg-purple/10 border border-purple/20 text-purple-300 rounded-lg text-sm font-medium">
        Thanks for subscribing! Check your inbox for a confirmation.
      </div>
    </div>
  </div>

  <script is:inline>
    document.getElementById('newsletter-form')?.addEventListener('submit', function (e) {
      e.preventDefault();
      // TODO: Connect to email service (Buttondown, ConvertKit, or Cloudflare Pages Function)
      var form = e.target;
      form.classList.add('hidden');
      document.getElementById('newsletter-success')?.classList.remove('hidden');
    });
  </script>
</section>
