---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="About — SaludConTech" description="SaludConTech is an inclusive ecosystem-building community that provides entrepreneurial support for digital health leaders from communities of color.">
  <Header />
  <main>
    <!-- Page Header -->
    <section class="section-padding bg-gradient-to-b from-purple-50/80 to-white">
      <div class="container-narrow">
        <div class="max-w-3xl">
          <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-purple/10 rounded-full mb-6 fade-in">
            <span class="text-purple text-sm font-medium">Our Story</span>
          </div>
          <h1 class="text-4xl sm:text-5xl font-extrabold text-navy mb-6 fade-in">
            Those closest to the problems hold the keys to
            <span class="gradient-text"> unlocking the solutions.</span>
          </h1>
          <p class="text-lg text-navy-700 leading-relaxed fade-in">
            SaludConTech is an inclusive ecosystem-building community that provides entrepreneurial support for digital health leaders from communities of color. Founded in 2020, it operates as the innovation and entrepreneurship arm of the broader Cultura Holdings ecosystem.
          </p>
        </div>
      </div>
    </section>

    <!-- Mission -->
    <section class="section-padding">
      <div class="container-narrow">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
          <div class="fade-in-left">
            <h2 class="text-3xl font-bold text-navy mb-6">Our Mission</h2>
            <p class="text-navy-700 text-lg leading-relaxed mb-6">
              SaludConTech curates, connects, and accelerates the founders who will fix health tech's equity gap. We provide community infrastructure, entrepreneurial support, and the bridge between clinical expertise and technical execution.
            </p>
            <p class="text-navy-700 leading-relaxed">
              We are building the pipeline of founders from underserved communities who will create the health technology those communities actually need.
            </p>
          </div>
          <div class="fade-in-right">
            <h2 class="text-3xl font-bold text-navy mb-6">Why Now</h2>
            <ul class="space-y-4">
              <li class="flex gap-3">
                <div class="w-6 h-6 bg-purple/10 rounded-full flex-shrink-0 flex items-center justify-center mt-0.5">
                  <div class="w-2 h-2 bg-purple rounded-full"></div>
                </div>
                <p class="text-navy-700">Techqueria (25,000+ Latino tech professionals) was acquired, creating organizational uncertainty and members looking for a new home</p>
              </li>
              <li class="flex gap-3">
                <div class="w-6 h-6 bg-purple/10 rounded-full flex-shrink-0 flex items-center justify-center mt-0.5">
                  <div class="w-2 h-2 bg-purple rounded-full"></div>
                </div>
                <p class="text-navy-700">Latino-owned businesses grew 44% since 2019 (Stanford Latino Entrepreneurship Initiative)</p>
              </li>
              <li class="flex gap-3">
                <div class="w-6 h-6 bg-purple/10 rounded-full flex-shrink-0 flex items-center justify-center mt-0.5">
                  <div class="w-2 h-2 bg-purple rounded-full"></div>
                </div>
                <p class="text-navy-700">California investing $1.6 billion in community health worker programs, creating massive market for culturally intelligent health tech</p>
              </li>
              <li class="flex gap-3">
                <div class="w-6 h-6 bg-purple/10 rounded-full flex-shrink-0 flex items-center justify-center mt-0.5">
                  <div class="w-2 h-2 bg-purple rounded-full"></div>
                </div>
                <p class="text-navy-700">Colorado AI Act takes effect June 2026, forcing every AI health company to prove equitable performance</p>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Team -->
    <section class="section-padding gradient-section">
      <div class="container-narrow">
        <div class="text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-bold text-navy mb-4 fade-in">Leadership</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <!-- Daniel -->
          <div class="glass-card text-center fade-in">
            <div class="w-24 h-24 bg-purple/10 rounded-full mx-auto mb-4 flex items-center justify-center">
              <svg class="w-12 h-12 text-purple/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
            </div>
            <h3 class="font-bold text-navy text-lg">Dr. Daniel Turner-Lloveras</h3>
            <p class="text-purple text-sm font-medium mb-3">President / Founder</p>
            <p class="text-navy-700 text-sm leading-relaxed">
              15 years as a physician. Faculty at UCLA and USC Keck. HLTH Foundation Techquity Advisory Council.
            </p>
          </div>

          <!-- Community Director -->
          <div class="glass-card text-center border-dashed fade-in">
            <div class="w-24 h-24 bg-gray-100 rounded-full mx-auto mb-4 flex items-center justify-center">
              <svg class="w-12 h-12 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v16m8-8H4" />
              </svg>
            </div>
            <h3 class="font-bold text-navy text-lg">Community Director</h3>
            <p class="text-purple text-sm font-medium mb-3">Now Recruiting</p>
            <p class="text-navy-700 text-sm leading-relaxed">
              15-20 hrs/week. Volunteer to paid ($60K-$80K + equity) upon securing first $100K in grants.
            </p>
            <a href="/volunteer" class="text-purple text-sm font-medium mt-3 inline-block hover:underline">
              Learn more &rarr;
            </a>
          </div>

          <!-- Programs Director -->
          <div class="glass-card text-center border-dashed fade-in">
            <div class="w-24 h-24 bg-gray-100 rounded-full mx-auto mb-4 flex items-center justify-center">
              <svg class="w-12 h-12 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v16m8-8H4" />
              </svg>
            </div>
            <h3 class="font-bold text-navy text-lg">Programs Director</h3>
            <p class="text-gray-400 text-sm font-medium mb-3">Phase 2 Hire</p>
            <p class="text-navy-700 text-sm leading-relaxed">
              10-15 hrs/week. Will lead founder fellowships and accelerator programs.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Advisory Board -->
    <section class="section-padding">
      <div class="container-narrow">
        <div class="text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-bold text-navy mb-4 fade-in">Advisory Board</h2>
          <p class="text-navy-700 text-lg fade-in">Recruiting 5-7 members across health tech, policy, investing, community, and academia.</p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {[
            { seat: 'Health Tech Executive', why: 'Opens doors to health system partnerships' },
            { seat: 'Latino Health Policy', why: 'Grants credibility with foundations' },
            { seat: 'VC / Investor', why: 'Investor pipeline for SCT founders' },
            { seat: 'Community Organizer', why: 'Grounds strategy in community reality' },
            { seat: 'Tech Industry Leader', why: 'Technical credibility for AI equity work' },
            { seat: 'Academic / Researcher', why: 'Research partnerships, evidence base' },
          ].map((seat) => (
            <div class="p-6 border border-gray-200 rounded-xl hover:border-purple-200 transition-colors fade-in">
              <h3 class="font-bold text-navy mb-2">{seat.seat}</h3>
              <p class="text-navy-700 text-sm">{seat.why}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Ecosystem -->
    <section class="section-padding bg-navy text-white">
      <div class="container-narrow text-center">
        <h2 class="text-3xl sm:text-4xl font-bold mb-6 fade-in">Cultura Holdings Ecosystem</h2>
        <p class="text-gray-300 text-lg max-w-2xl mx-auto mb-8 fade-in">
          SaludConTech is the innovation and entrepreneurship arm of Cultura Holdings — a holding company building the infrastructure for Latino professional advancement.
        </p>
        <a href="/contact" class="btn-primary bg-white text-navy hover:bg-gray-100">
          Partner With Us
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
