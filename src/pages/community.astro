---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import InnerRings from '../components/InnerRings.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Community — SaludConTech" description="Join the SaludConTech community of Latino health tech founders, clinicians, and builders.">
  <Header />
  <main>
    <!-- Page Header -->
    <section class="section-padding bg-gradient-to-b from-purple-50/80 to-white">
      <div class="container-narrow">
        <div class="max-w-3xl">
          <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-purple/10 rounded-full mb-6 fade-in">
            <span class="text-purple text-sm font-medium">Join Us</span>
          </div>
          <h1 class="text-4xl sm:text-5xl font-extrabold text-navy mb-6 fade-in">
            A Community That
            <span class="gradient-text"> Gets It.</span>
          </h1>
          <p class="text-lg text-navy-700 leading-relaxed fade-in">
            SaludConTech is not a networking event. It is a gathering place where people can be their full selves, speak Spanglish, share frustrations about the system, and find collaborators who understand.
          </p>
        </div>
      </div>
    </section>

    <!-- Principles -->
    <section class="section-padding">
      <div class="container-narrow">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <!-- Shared Values -->
          <div class="glass-card fade-in">
            <div class="w-12 h-12 bg-purple/10 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-purple" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <h3 class="font-bold text-navy text-xl mb-3">Shared Values</h3>
            <p class="text-navy-700 leading-relaxed">
              We believe health technology should work for everyone, and the people building it should reflect the communities it serves. That is our boundary. If you believe that, you belong here.
            </p>
          </div>

          <!-- Sacred Space -->
          <div class="glass-card fade-in">
            <div class="w-12 h-12 bg-purple/10 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-purple" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
              </svg>
            </div>
            <h3 class="font-bold text-navy text-xl mb-3">Our Sacred Space</h3>
            <p class="text-navy-700 leading-relaxed">
              Our Slack workspace and in-person dinners are not networking events. They are gathering places where people can be their full selves and find collaborators who get it.
            </p>
          </div>

          <!-- Exclusivity -->
          <div class="glass-card fade-in">
            <div class="w-12 h-12 bg-purple/10 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-purple" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
              </svg>
            </div>
            <h3 class="font-bold text-navy text-xl mb-3">Earned Belonging</h3>
            <p class="text-navy-700 leading-relaxed">
              The application and interview are intentional friction. People who go through a selection process value their membership more. This community is worth earning your way into.
            </p>
          </div>

          <!-- Rituals -->
          <div class="glass-card fade-in">
            <div class="w-12 h-12 bg-purple/10 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-purple" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
            <h3 class="font-bold text-navy text-xl mb-3">Our Rituals</h3>
            <p class="text-navy-700 leading-relaxed">
              Monthly virtual calls, quarterly LA dinners (Sobremesa format), weekly Monday Slack prompts, and personal welcome DMs within 24 hours for every new member.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Inner Rings -->
    <div class="gradient-section">
      <InnerRings />
    </div>

    <!-- How to Join -->
    <section class="section-padding">
      <div class="container-narrow">
        <div class="text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-bold text-navy mb-4 fade-in">How to Join</h2>
        </div>

        <div class="max-w-3xl mx-auto">
          <div class="space-y-8">
            <!-- Step 1 -->
            <div class="flex gap-6 fade-in">
              <div class="flex-shrink-0">
                <div class="w-10 h-10 bg-purple rounded-full flex items-center justify-center text-white font-bold">1</div>
              </div>
              <div>
                <h3 class="font-bold text-navy text-lg mb-2">Apply</h3>
                <p class="text-navy-700">Fill out our short application form. Tell us about yourself, your work, and why you want to join.</p>
              </div>
            </div>

            <!-- Step 2 -->
            <div class="flex gap-6 fade-in">
              <div class="flex-shrink-0">
                <div class="w-10 h-10 bg-purple rounded-full flex items-center justify-center text-white font-bold">2</div>
              </div>
              <div>
                <h3 class="font-bold text-navy text-lg mb-2">Brief Interview</h3>
                <p class="text-navy-700">A 15-minute chat to make sure we are a good fit for each other. We want to know your story.</p>
              </div>
            </div>

            <!-- Step 3 -->
            <div class="flex gap-6 fade-in">
              <div class="flex-shrink-0">
                <div class="w-10 h-10 bg-purple rounded-full flex items-center justify-center text-white font-bold">3</div>
              </div>
              <div>
                <h3 class="font-bold text-navy text-lg mb-2">Welcome to Slack</h3>
                <p class="text-navy-700">Get access to our Slack workspace, a personal welcome DM, and an introduction to the community.</p>
              </div>
            </div>
          </div>

          <div class="text-center mt-12 fade-in">
            <a href="/contact" class="btn-primary">
              Apply Now
              <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Events -->
    <section class="section-padding bg-navy text-white">
      <div class="container-narrow">
        <div class="text-center mb-12">
          <h2 class="text-3xl sm:text-4xl font-bold mb-4 fade-in">Events</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="p-8 rounded-2xl bg-white/5 border border-white/10 fade-in">
            <h3 class="font-bold text-xl mb-3">Monthly Virtual Call</h3>
            <p class="text-gray-300 leading-relaxed mb-4">
              30 minutes, informal, share wins and ask for help. Open to all members.
            </p>
            <span class="text-purple-300 text-sm font-medium">Every month</span>
          </div>

          <div class="p-8 rounded-2xl bg-white/5 border border-white/10 fade-in">
            <h3 class="font-bold text-xl mb-3">Sobremesa Dinner (LA)</h3>
            <p class="text-gray-300 leading-relaxed mb-4">
              Curated in-person dinner for 12-15 people. Builders only. Quarterly in Los Angeles.
            </p>
            <span class="text-purple-300 text-sm font-medium">Quarterly in LA</span>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
