---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact — SaludConTech" description="Get in touch with SaludConTech. Apply to join, partner with us, or ask a question.">
  <Header />
  <main>
    <!-- Page Header -->
    <section class="section-padding bg-gradient-to-b from-purple-50/80 to-white">
      <div class="container-narrow">
        <div class="max-w-3xl">
          <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-purple/10 rounded-full mb-6 fade-in">
            <span class="text-purple text-sm font-medium">Get In Touch</span>
          </div>
          <h1 class="text-4xl sm:text-5xl font-extrabold text-navy mb-6 fade-in">
            Let's
            <span class="gradient-text"> Connect.</span>
          </h1>
          <p class="text-lg text-navy-700 leading-relaxed fade-in">
            Whether you want to join the community, volunteer, partner, or just say hello — we would love to hear from you.
          </p>
        </div>
      </div>
    </section>

    <!-- Contact Form + Info -->
    <section class="section-padding">
      <div class="container-narrow">
        <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">
          <!-- Form -->
          <div class="lg:col-span-3">
            <form id="contact-form" class="space-y-6 fade-in">
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div>
                  <label for="name" class="block text-sm font-medium text-navy mb-2">Name</label>
                  <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    class="w-full px-4 py-3 rounded-lg border border-gray-200 bg-white text-navy placeholder:text-gray-400
                           focus:outline-none focus:ring-2 focus:ring-purple/50 focus:border-purple transition-all"
                    placeholder="Your name"
                  />
                </div>
                <div>
                  <label for="email" class="block text-sm font-medium text-navy mb-2">Email</label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    required
                    class="w-full px-4 py-3 rounded-lg border border-gray-200 bg-white text-navy placeholder:text-gray-400
                           focus:outline-none focus:ring-2 focus:ring-purple/50 focus:border-purple transition-all"
                    placeholder="your@email.com"
                  />
                </div>
              </div>

              <div>
                <label for="subject" class="block text-sm font-medium text-navy mb-2">I am interested in...</label>
                <select
                  id="subject"
                  name="subject"
                  class="w-full px-4 py-3 rounded-lg border border-gray-200 bg-white text-navy
                         focus:outline-none focus:ring-2 focus:ring-purple/50 focus:border-purple transition-all"
                >
                  <option value="join">Joining the Community</option>
                  <option value="volunteer">Volunteering</option>
                  <option value="partner">Corporate Partnership</option>
                  <option value="advisory">Advisory Board</option>
                  <option value="media">Media / Press</option>
                  <option value="other">Something Else</option>
                </select>
              </div>

              <div>
                <label for="message" class="block text-sm font-medium text-navy mb-2">Message</label>
                <textarea
                  id="message"
                  name="message"
                  rows="5"
                  required
                  class="w-full px-4 py-3 rounded-lg border border-gray-200 bg-white text-navy placeholder:text-gray-400
                         focus:outline-none focus:ring-2 focus:ring-purple/50 focus:border-purple transition-all resize-none"
                  placeholder="Tell us about yourself and how we can help..."
                ></textarea>
              </div>

              <button type="submit" class="btn-primary w-full sm:w-auto">
                Send Message
                <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                </svg>
              </button>
            </form>

            <!-- Success message -->
            <div id="contact-success" class="hidden mt-6 p-6 bg-green-50 text-green-700 rounded-xl text-center">
              <p class="font-semibold text-lg mb-2">Message sent!</p>
              <p class="text-sm">We will get back to you within 48 hours.</p>
            </div>
          </div>

          <!-- Contact Info -->
          <div class="lg:col-span-2">
            <div class="space-y-8 fade-in-right">
              <div>
                <h3 class="font-bold text-navy mb-3">Email</h3>
                <a href="mailto:info@saludcontech.com" class="text-purple hover:underline">
                  info@saludcontech.com
                </a>
              </div>

              <div>
                <h3 class="font-bold text-navy mb-3">Location</h3>
                <p class="text-navy-700">Los Angeles, California</p>
              </div>

              <div>
                <h3 class="font-bold text-navy mb-4">Follow Us</h3>
                <div class="flex gap-4">
                  <a
                    href="https://www.linkedin.com/company/saludcontech/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="w-12 h-12 rounded-xl bg-purple/10 flex items-center justify-center hover:bg-purple hover:text-white text-purple transition-all"
                    aria-label="LinkedIn"
                  >
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                    </svg>
                  </a>
                  <a
                    href="https://www.instagram.com/saludcontech/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="w-12 h-12 rounded-xl bg-purple/10 flex items-center justify-center hover:bg-purple hover:text-white text-purple transition-all"
                    aria-label="Instagram"
                  >
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
                    </svg>
                  </a>
                  <a
                    href="https://saludcontech.slack.com"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="w-12 h-12 rounded-xl bg-purple/10 flex items-center justify-center hover:bg-purple hover:text-white text-purple transition-all"
                    aria-label="Slack"
                  >
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M5.042 15.165a2.528 2.528 0 0 1-2.52 2.523A2.528 2.528 0 0 1 0 15.165a2.527 2.527 0 0 1 2.522-2.52h2.52v2.52zM6.313 15.165a2.527 2.527 0 0 1 2.521-2.52 2.527 2.527 0 0 1 2.521 2.52v6.313A2.528 2.528 0 0 1 8.834 24a2.528 2.528 0 0 1-2.521-2.522v-6.313zM8.834 5.042a2.528 2.528 0 0 1-2.521-2.52A2.528 2.528 0 0 1 8.834 0a2.528 2.528 0 0 1 2.521 2.522v2.52H8.834zM8.834 6.313a2.528 2.528 0 0 1 2.521 2.521 2.528 2.528 0 0 1-2.521 2.521H2.522A2.528 2.528 0 0 1 0 8.834a2.528 2.528 0 0 1 2.522-2.521h6.312zM18.956 8.834a2.528 2.528 0 0 1 2.522-2.521A2.528 2.528 0 0 1 24 8.834a2.528 2.528 0 0 1-2.522 2.521h-2.522V8.834zM17.688 8.834a2.528 2.528 0 0 1-2.523 2.521 2.527 2.527 0 0 1-2.52-2.521V2.522A2.527 2.527 0 0 1 15.165 0a2.528 2.528 0 0 1 2.523 2.522v6.312zM15.165 18.956a2.528 2.528 0 0 1 2.523 2.522A2.528 2.528 0 0 1 15.165 24a2.527 2.527 0 0 1-2.52-2.522v-2.522h2.52zM15.165 17.688a2.527 2.527 0 0 1-2.52-2.523 2.526 2.526 0 0 1 2.52-2.52h6.313A2.527 2.527 0 0 1 24 15.165a2.528 2.528 0 0 1-2.522 2.523h-6.313z"/>
                    </svg>
                  </a>
                </div>
              </div>

              <div class="p-6 bg-purple-50 rounded-xl">
                <h3 class="font-bold text-navy mb-2">Quick Apply</h3>
                <p class="text-navy-700 text-sm mb-4">Want to skip the form? Apply directly to join our community.</p>
                <a href="/community" class="text-purple font-medium text-sm hover:underline">
                  See membership options &rarr;
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />

  <script is:inline>
    document.getElementById('contact-form')?.addEventListener('submit', function (e) {
      e.preventDefault();
      // TODO: Connect to Cloudflare Pages Function or email service
      var form = e.target;
      form.classList.add('hidden');
      document.getElementById('contact-success')?.classList.remove('hidden');
    });
  </script>
</Layout>
